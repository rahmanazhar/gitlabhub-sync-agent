# Copy to .env and fill in. Never commit the real .env file.
#
# GitHub: a Personal Access Token (classic or fine-grained) or a GitHub App
# installation token with 'repo' (contents + pull requests) scope.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitLab: a Personal Access Token, or a group/project access token, with the
# 'api' and 'write_repository' scopes.
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx
